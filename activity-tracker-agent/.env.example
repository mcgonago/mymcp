# Activity Tracker Agent Configuration
# =====================================
#
# INCREMENTAL SETUP: You don't need all platforms!
# Configure only the platforms you want to track.
# Unconfigured platforms are automatically skipped.
#

# ===================
# WORKSPACE (Required)
# ===================
WORKSPACE_PROJECT=/home/omcgonag/Work/mymcp/workspace/iproject

# Cache validity (hours) - set to 0 to always fetch fresh
CACHE_MAX_AGE_HOURS=24

# ===================
# OPENDEV (Optional)
# ===================
# No token needed - public API
# Just set your username to track your reviews
OPENDEV_USERNAME=your_opendev_username

# ===================
# GITHUB (Optional)
# ===================
# Requires: username + token
# Token: https://github.com/settings/tokens (scopes: repo, read:org, read:user)
# GITHUB_USERNAME=your_github_username
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ===================
# GITLAB (Optional)
# ===================
# Requires: username + token + url
# Token: GitLab → User Settings → Access Tokens (scopes: read_api, read_repository)
# GITLAB_USERNAME=your_gitlab_username
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# GITLAB_URL=https://gitlab.cee.redhat.com

# ===================
# JIRA (Optional)
# ===================
# Requires: email + token + url
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_EMAIL=your.email@company.com
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_URL=https://issues.redhat.com

# ===================
# QUICK START EXAMPLES
# ===================
#
# Example 1: Jira only
#   WORKSPACE_PROJECT=~/Work/mymcp/workspace/iproject
#   JIRA_EMAIL=you@company.com
#   JIRA_API_TOKEN=xxx
#   JIRA_URL=https://issues.redhat.com
#
# Example 2: OpenDev + GitHub
#   WORKSPACE_PROJECT=~/Work/mymcp/workspace/iproject
#   OPENDEV_USERNAME=yourusername
#   GITHUB_USERNAME=yourusername
#   GITHUB_TOKEN=ghp_xxx
#
# Example 3: All platforms
#   (uncomment all sections above)
