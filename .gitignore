# Review workspace - temporary clones for code review analysis
# Use workspace/* (not workspace/) to allow negation patterns to work
# Allow documentation and scripts in workspace
workspace/*
!workspace/docs/
!workspace/scripts/
!workspace/README.md
reviews/

# External work areas (confidential, not tracked in public repo)
# Note: No trailing slash for symlinks - gitignore pattern customer-work (not customer-work/)
customer-work
rh-internal
scratch-*/

# Personal configuration with sensitive paths
.mymcp-config
workspace/external/
